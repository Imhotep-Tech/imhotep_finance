# frontend/imhotep_finance/Dockerfile.prod

# Stage 1: Build the React App
FROM node:20-alpine as build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
# Compile the app using Vite
RUN npm run build 

# Stage 2: Serve the App with Nginx
FROM nginx:alpine
# Copy the compiled static files to Nginx's HTML folder
COPY --from=build /app/dist /usr/share/nginx/html
# Expose port 80
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
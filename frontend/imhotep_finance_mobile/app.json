{
  "expo": {
    "name": "Imhotep Financial Manager",
    "slug": "imhotep-finance",
    "version": "2.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/imhotep_finance_zoomed.png",
    "scheme": "imhotep-finance",
    "userInterfaceStyle": "automatic",
    "ios": {
      "associatedDomains": [
        "applinks:imhotep-finance.vercel.app"
      ],
      "bundleIdentifier": "com.imhoteptech.imhotep_finance"
    },
    "android": {
      "package": "com.imhoteptech.imhotep_finance",
      "versionCode": 3,
      "permissions": [
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/imhotep_finance_zoomed.png",
        "backgroundColor": "#366c6b"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "imhotep-finance.vercel.app",
              "pathPrefix": "/verify-email"
            },
            {
              "scheme": "https",
              "host": "imhotep-finance.vercel.app",
              "pathPrefix": "/verify-email-change"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/imhotep_finance.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/imhotep_finance.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "fonts": [],
          "widgets": [
            {
              "name": "NetWorthWidget",
              "label": "Net Worth",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "Total net worth and score",
              "previewImage": "./assets/images/widget_preview_networth.png",
              "updatePeriodMillis": 0
            }
          ]
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-status-bar",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1a10f77-5fb8-4ce7-b257-80e64d5dbb2a"
      }
    },
    "owner": "imhoteptech",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c1a10f77-5fb8-4ce7-b257-80e64d5dbb2a"
    }
  }
}

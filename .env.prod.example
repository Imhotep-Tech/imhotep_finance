# =============================================================================
#  Imhotep Finance — Production Environment Variables
# =============================================================================
#
#  Copy this file to .env in the same directory as docker-compose.prod.yml:
#    cp .env.prod.example .env
#
#  Then update all values marked with "CHANGE_ME" before starting.
#
# =============================================================================


# =============================================================================
# PostgreSQL Database (used by the 'db' container)
# =============================================================================
# These create the database and user inside the Postgres container.
POSTGRES_DB=imhotep_finance_db
POSTGRES_USER=imhotep_finance_user
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password


# =============================================================================
# Django Backend — Database Connection
# =============================================================================
# These must match the Postgres values above so the backend can connect.
database_type=postgresql
DATABASE_NAME=imhotep_finance_db
DATABASE_USER=imhotep_finance_user
DATABASE_PASSWORD=CHANGE_ME_use_a_strong_password
DATABASE_HOST=db
DATABASE_PORT=5432


# =============================================================================
# Django Backend — Core Settings
# =============================================================================

# IMPORTANT: Set to False for production
DEBUG=False

# SSL Redirect — Set to True to force HTTPS.
# IMPORTANT: Set to False if testing locally on http://localhost or over IP without SSL.
SECURE_SSL_REDIRECT=True

# Django secret key (REQUIRED — must be unique and private)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_generate_a_secret_key

# Field encryption key (REQUIRED — used to encrypt sensitive data in the DB)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose this key, encrypted data cannot be recovered!
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key

# Allowed hosts — add your domain name(s)
ALLOWED_HOSTS=localhost,127.0.0.1,backend,your-domain.com

# Your backend URL (used for OAuth redirects and CORS)
SITE_DOMAIN=http://localhost:8000

# Your frontend URL (used for CORS and email links)
frontend_url=http://localhost

# CORS — which origins can call the API
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80


# =============================================================================
# Email Configuration (Optional but recommended)
# =============================================================================
# For Gmail: enable 2FA, then create an App Password:
#   https://myaccount.google.com/apppasswords
#
# If not configured, email features (password reset, verification) won't work.
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password


# =============================================================================
# Google OAuth (Optional)
# =============================================================================
# To enable Google Sign-In:
#   1. Go to https://console.cloud.google.com/
#   2. Create OAuth 2.0 credentials
#   3. Add redirect URI: http://your-domain:8000/api/auth/google/callback/
#
# Leave as-is if you don't need Google login.
GOOGLE_CLIENT_ID=not-configured
GOOGLE_CLIENT_SECRET=not-configured
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/


# =============================================================================
# Exchange Rates API (Optional)
# =============================================================================
# Get a free API key at: https://www.imhotepexchangeratesapi.pythonanywhere.com/
# Required for multi-currency support.
EXCHANGE_API_KEY_PRIMARY=not-configured
